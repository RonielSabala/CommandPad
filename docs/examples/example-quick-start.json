{
  "variables": [
    {
      "key": "API_HOST",
      "value": "api.example.com"
    },
    {
      "key": "PORT",
      "value": "8080"
    },
    {
      "key": "API_KEY",
      "value": "sk-abc123xyz",
      "secret": true
    }
  ],
  "blocks": [
    {
      "type": "note",
      "text": "API Testing Commands",
      "style": "heading"
    },
    {
      "type": "note",
      "text": "Change the **variables** in the sidebar and watch all commands update _instantly_.",
      "style": "body"
    },
    {
      "type": "divider"
    },
    {
      "type": "command",
      "text": "curl http://{API_HOST}:{PORT}/status",
      "editorCollapsed": true
    },
    {
      "type": "note",
      "text": "Fetch users with authentication using `curl`. See https://curl.se for more curl options.",
      "style": "body"
    },
    {
      "type": "command",
      "text": "curl -X POST http://{API_HOST}:{PORT}/auth -d \"key={API_KEY}\"",
      "editorCollapsed": true
    },
    {
      "type": "note",
      "text": "Authenticate with the **API_KEY** variable, sent as the `key` parameter.",
      "style": "body"
    },
    {
      "type": "command",
      "text": "ssh deploy@{API_HOST} -p {PORT} 'systemctl status api'",
      "editorCollapsed": true
    },
    {
      "type": "note",
      "text": "Check `systemctl` service status on the _production_ server over SSH.",
      "style": "body"
    },
    {
      "type": "command",
      "text": "docker logs server | grep {API_KEY}",
      "editorCollapsed": true
    },
    {
      "type": "note",
      "text": "Learn more at https://docs.docker.com/engine/reference/commandline/logs/",
      "style": "body"
    }
  ]
}
