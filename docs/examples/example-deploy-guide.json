{
  "variables": [
    {
      "key": "NAMESPACE",
      "value": "production"
    },
    {
      "key": "POD_NAME",
      "value": "my-app-deployment-5d4f8c6b7-x9k2m"
    },
    {
      "key": "CONTAINER_NAME",
      "value": "api-server"
    },
    {
      "key": "IMAGE_TAG",
      "value": "v2.1.0-prod"
    },
    {
      "key": "DOCKER_REGISTRY",
      "value": "gcr.io/my-project"
    },
    {
      "key": "CLUSTER_NAME",
      "value": "prod-us-central1"
    }
  ],
  "blocks": [
    {
      "type": "note",
      "text": "Kubernetes Deployment & Debugging Guide",
      "style": "heading"
    },
    {
      "type": "note",
      "text": "A complete workflow for deploying and debugging your application in Kubernetes. Contains common kubectl commands and debugging procedures.",
      "style": "body"
    },
    {
      "type": "divider"
    },
    {
      "type": "note",
      "text": "Prerequisites & Setup",
      "style": "subheading"
    },
    {
      "type": "note",
      "text": "Make sure you have kubectl installed and configured. Visit https://kubernetes.io/docs/tasks/tools/ for installation instructions.",
      "style": "body"
    },
    {
      "type": "command",
      "text": "kubectl config current-context",
      "editorCollapsed": true
    },
    {
      "type": "command",
      "text": "kubectl get namespaces | grep {NAMESPACE}",
      "editorCollapsed": true
    },
    {
      "type": "divider"
    },
    {
      "type": "note",
      "text": "Deployment & Image Management",
      "style": "subheading"
    },
    {
      "type": "command",
      "text": "docker build -t {DOCKER_REGISTRY}/my-app:{IMAGE_TAG} .",
      "editorCollapsed": true
    },
    {
      "type": "command",
      "text": "docker push {DOCKER_REGISTRY}/my-app:{IMAGE_TAG}",
      "editorCollapsed": true
    },
    {
      "type": "command",
      "text": "kubectl set image deployment/my-app-deployment my-app={DOCKER_REGISTRY}/my-app:{IMAGE_TAG} -n {NAMESPACE}",
      "editorCollapsed": true
    },
    {
      "type": "command",
      "text": "kubectl rollout status deployment/my-app-deployment -n {NAMESPACE}",
      "editorCollapsed": true
    },
    {
      "type": "divider"
    },
    {
      "type": "note",
      "text": "Pod Inspection & Logs",
      "style": "subheading"
    },
    {
      "type": "command",
      "text": "kubectl get pods -n {NAMESPACE} -o wide",
      "editorCollapsed": true
    },
    {
      "type": "command",
      "text": "kubectl describe pod {POD_NAME} -n {NAMESPACE}",
      "editorCollapsed": true
    },
    {
      "type": "command",
      "text": "kubectl logs {POD_NAME} -n {NAMESPACE} -c {CONTAINER_NAME} --tail=100",
      "editorCollapsed": true
    },
    {
      "type": "command",
      "text": "kubectl logs {POD_NAME} -n {NAMESPACE} -c {CONTAINER_NAME} --previous",
      "editorCollapsed": true
    },
    {
      "type": "note",
      "text": "Useful for viewing logs from a crashed container that has been restarted.",
      "style": "body"
    },
    {
      "type": "divider"
    },
    {
      "type": "note",
      "text": "Interactive Debugging",
      "style": "subheading"
    },
    {
      "type": "command",
      "text": "kubectl exec -it {POD_NAME} -n {NAMESPACE} -c {CONTAINER_NAME} -- /bin/bash",
      "editorCollapsed": true
    },
    {
      "type": "note",
      "text": "Enter interactive shell in the pod. Check environment variables, logs, and running processes.",
      "style": "body"
    },
    {
      "type": "command",
      "text": "kubectl port-forward {POD_NAME} 8080:8080 -n {NAMESPACE}",
      "editorCollapsed": true
    },
    {
      "type": "note",
      "text": "Forward local port 8080 to the pod's port 8080. Now access the service at http://localhost:8080",
      "style": "body"
    },
    {
      "type": "divider"
    },
    {
      "type": "note",
      "text": "Useful Resources",
      "style": "subheading"
    },
    {
      "type": "note",
      "text": "Check the official kubectl documentation at https://kubernetes.io/docs/reference/kubectl/ for more commands.\n\nLearn more about debugging Kubernetes applications: https://kubernetes.io/docs/tasks/debug-application-cluster/",
      "style": "body"
    }
  ]
}
